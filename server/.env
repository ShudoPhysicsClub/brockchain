# Brockchain ノード設定

# DNS Seed: 複数TXTレコードから node list 取得
# DNS登録例:
#   _nodes.seed.shudo-physics.com TXT "node=node1.shudo-physics.com:8333"
#   _nodes.seed.shudo-physics.com TXT "node=node2.shudo-physics.com:8333"
#   _nodes.seed.shudo-physics.com TXT "node=mail.shudo-physics.com:8333"
# ※ client 側は DoH(TXT) で node=host:port を取得可能
DNS_SEED=manh2309.org

# データディレクトリ（ブロックチェーン永続化）
DATA_DIR=./data

# P2P サーバーポート（ノード間通信）
P2P_PORT=8333

# JSON-RPC サーバーポート（API / Web アクセス用）
# アクセス例: curl -X POST http://localhost:59988 -d '{"to":"0x...", "from":"0x...", "amount":"100"}'
# ※ 現在は 59988 固定（設定値は使われません）
# JSONRPC_PORT=59988

# TLS/HTTPS 設定
TLS_CERT_FILE=./certs/server.crt
TLS_KEY_FILE=./certs/server.key
TLS_CHECK_INTERVAL=24h
TLS_RESTART_ON_ROTATE=true

# リスナーホスト（JSON-RPC と P2P サーバー用）
# 127.0.0.1: localhost のみリッスン
# 0.0.0.0: すべてのインターフェースでリッスン
LISTEN_HOST=127.0.0.1

# TLS 証明書チェック間隔（例: 24h, 12h）
TLS_CHECK_INTERVAL=24h

# 証明書/鍵の差し替えを検知したらプロセスを終了（再起動で反映）
TLS_RESTART_ON_ROTATE=true

# アウトバウンド接続数（DNS Seed から取得したノードへの接続数）
MAX_OUTBOUND_PEERS=8
